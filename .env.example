# SylibOS — standalone deployment env vars
# Copy to .env and fill in every value before running docker compose up.
#
# The frontend (SPA) has no runtime env vars — the user configures the AI
# provider and backend URL in the Settings page, which are persisted to
# localStorage and synced to the backend DB.
#
# The backend reads the values below as *defaults* for the nightly AI job.
# Any setting saved from the Settings UI in the browser overrides these.

# ── Backend port & database ───────────────────────────────────────────────────
PORT=8004
# DB_PATH is forced to /data/sylibos.db inside the container (see compose).

# ── jkOS Auth (SSO) ───────────────────────────────────────────────────────────
# RS256 public key from jkos-auth service (newlines as \n).
# Copy from jkos-auth/.env — do not change independently.
JKOS_AUTH_PUBLIC_KEY=
JKOS_AUTH_URL=https://auth.jkos.net

# ── Frontend env vars (passed to Vite at build time) ─────────────────────────
VITE_JKOS_AUTH_URL=https://auth.jkos.net
VITE_APP_ORIGIN=https://sylibos.jkos.net

# ── Nightly AI job schedule ───────────────────────────────────────────────────
# Standard cron syntax (minute hour day month weekday). Default: 2am daily.
NIGHTLY_CRON=0 2 * * *

# ── AI provider for the nightly segment-generation job ───────────────────────
# Options: lazuros | ollama | none
# "lazuros" is recommended when LazurOS is running (routes through local Ollama
# via Wake-on-LAN). "none" generates placeholder quizzes — no LLM required.
AI_PROVIDER=lazuros

# ── LazurOS (if AI_PROVIDER=lazuros) ─────────────────────────────────────────
# Docker containers reach LazurOS (host network, port 8080) via host.docker.internal.
# LAZUROS_TOKEN must match the token set in LazurOS/.env and BeigeBoard/.env.
LAZUROS_URL=http://host.docker.internal:8080
LAZUROS_TOKEN=

# ── Ollama direct (if AI_PROVIDER=ollama) ────────────────────────────────────
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
