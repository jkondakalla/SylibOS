# OpenCourseFlow API — copy to .env and fill in values

PORT=8004
DB_PATH=/data/opencourseflow.db

# Shared JWT secret (must match ORDECK's JWT_SECRET to use the same token)
# Leave empty to run without auth (fine for local/private use)
JWT_SECRET=

# Nightly cron schedule (default: 2am daily)
# Uses standard cron syntax: minute hour day month weekday
NIGHTLY_CRON=0 2 * * *

# AI provider for nightly segment generation
# Options: lazuros | ollama | none
AI_PROVIDER=ollama

# Ollama (if AI_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# LazurOS (if AI_PROVIDER=lazuros)
LAZUROS_URL=http://host.docker.internal:8080
LAZUROS_TOKEN=

# URL of the standalone OpenCourseFlow frontend (for deep links in ORDECK widget)
OCF_APP_URL=https://YOUR_DOMAIN/ocf
